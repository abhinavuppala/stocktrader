# Copy this file to .env and fill in your values
# .env is gitignored — never commit real secrets

# Anthropic (Phase 3+)
ANTHROPIC_API_KEY=

# Finnhub news API (Phase 2+) — free tier at finnhub.io
FINNHUB_API_KEY=

# Alpaca trading API (Phase 4+) — paper trading at alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# App settings (can also be set in config.yaml)
STOCKTRADER_ENV=development       # development | production
STOCKTRADER_LOG_LEVEL=INFO
STOCKTRADER_BROKER_MODE=mock      # mock | alpaca
